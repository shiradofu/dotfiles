#!/bin/sh

# tmux status line

! git rev-parse --is-inside-work-tree > /dev/null 2>&1 && return
case $1 in
  -a )
    NUM_AHEAD="$(git log --oneline @{u}.. 2> /dev/null | wc -l | tr -d ' ')"
    echo "$NUM_AHEAD"
    ;;
  -b )
    NUM_BEHIND="$(git log --oneline ..@{u} 2> /dev/null | wc -l | tr -d ' ')"
    echo "$NUM_BEHIND"
    ;;
  -d )
    diff_files=$(git diff --name-only HEAD | grep -v \
      -e 'composer.lock' \
      -e 'package-lock.json' \
      -e 'yarn.lock' \
      -e '\(\.png\|\.jpg\|\.jpeg\)' \
    )
    [ -z "$diff_files" ] && echo "0 | 0[+] | 0[-]" && exit 0
    echo $( git diff --stat HEAD $diff_files |
      tail -n 1 | awk '{printf "%s | %s[+] | %s[-]", \
      ($1==""?"0":$1),($4==""?"0":$4),($6==""?"0":$6)}' \
    )
    ;;
  -l )
    echo $(git branch --contains | cut -c 3-)
    ;;
  -m )
    GIT_DIR="$(git rev-parse --git-dir 2> /dev/null)"
    if [ -n $GIT_DIR ] && test -r $GIT_DIR/MERGE_HEAD; then echo 1; else echo 0; fi
    ;;
  -s )
    [ -n "$(git stash list)" ] && echo 1 || echo 0
esac
