#!/bin/sh

# tmux status line

basic_colour="#[fg=colour248]"
cd $2

diff_exclude() {
  echo \
  ':(exclude)**/composer.lock' \
  ':(exclude)**/package-lock.json' \
  ':(exclude)**/yarn.lock' \
  ':(exclude)**/.png' \
  ':(exclude)**/.jpg' \
  ':(exclude)**/.jpeg'
}

diff_head() {
  git diff --stat HEAD "$(diff_exclude)" | \
    tail -n 1 | awk '{printf "%s | %s[+] | %s[-]", \
    ($1==""?"#[fg=colour248] 0":($1>10?"#[fg=colour001] "$1:($1>7?"#[fg=colour011] "$1:"#[fg=colour248] "$1))), \
    ($4==""?"#[fg=colour248]0":($4>300?"#[fg=colour001]"$4:($4>200?"#[fg=colour011]"$4:"#[fg=colour248]"$4))), \
    ($6==""?"#[fg=colour248]0":($6>300?"#[fg=colour001]"$6:($6>200?"#[fg=colour011]"$6:"#[fg=colour248]"$6)))  \
  }'
}

diff_junction() {
  junction=$(git show-branch | grep '*[^[]\+\[' | \
    grep -vF "[$(git rev-parse --abbrev-ref HEAD)" | \
    head -1 | awk -F'[]~^[]' '{print $2}' \
  )

  git diff --stat "$junction" "$(diff_exclude)" |
    tail -n 1 | awk '{printf "%s", \
    ($1==""?"#[fg=colour248] 0":($1>20?"#[fg=colour001] "$1:($1>10?"#[fg=colour011] "$1:"#[fg=colour248] "$1)))
  }'
}

case "$1" in
-l )
if git rev-parse --is-inside-work-tree > /dev/null 2>&1; then
  git_dir=$(basename $(git rev-parse --show-toplevel))
  branch="$(git branch --contains | cut -c 3-)"
  [ -z "$(git status -s)" ] && status="" || status="⚹"
  result="${basic_colour} ${git_dir} → ${branch}${status}"
else
  result="${basic_colour}--- not in git directory ---"
fi
;;

-r )
if git rev-parse --is-inside-work-tree > /dev/null 2>&1; then
  if [ -n "$(git stash list)" ]; then
    stash="#[fg=colour220]${basic_colour}"
  else
    stash=""
    stash="#[fg=colour220]${basic_colour}"
  fi

  GIT_DIR="$(git rev-parse --git-dir 2> /dev/null)"
  if [ -d $GIT_DIR ] && test -r $GIT_DIR/MERGE_HEAD; then
    merging="#[fg=colour011]⚡︎${basic_colour}"
  else
    merging=""
    merging="#[fg=colour011]⚡︎${basic_colour}"
  fi

  num_ahead="$(git log --oneline @{u}.. 2> /dev/null | wc -l | tr -d ' ')"
  if [ "$num_ahead" -gt 0 ]; then
    ahead="#[fg=colour001]⇡${num_ahead}${basic_colour}"
  else
    ahead="${basic_colour}⇡${num_ahead}${basic_colour}"
  fi

  num_behind="$(git log --oneline ..@{u} 2> /dev/null | wc -l | tr -d ' ')"
  if [ "$num_behind" -gt 0 ]; then
    behind="#[fg=colour004]⇣${num_behind$}${basic_colour}"
  else
    behind="${basic_colour}⇣${num_behind}${basic_colour}"
  fi

  result="${stash}   ${merging} ${ahead} ${behind}  $(diff_head)  $(diff_junction)"
else
  result=""
fi
esac

echo "$result"
